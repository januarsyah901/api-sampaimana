datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


generator client {
  provider = "prisma-client-js"
}


enum Role {
  SUPER_ADMIN
  EDITOR
  VIEWER
  CONTRIBUTOR
}

enum CaseStatus {
  PELAPORAN
  PENYIDIKAN
  PENUNTUTAN
  PERSIDANGAN
  PUTUSAN
}

enum StageStatus {
  PENDING
  AKTIF
  SELESAI
}

enum ContributionStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                   String             @id @default(uuid())
  email                String             @unique
  passwordHash         String
  name                 String
  role                 Role               @default(CONTRIBUTOR)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  stagesCreated        CaseStage[]        @relation("StageCreator")
  articlesCreated      Article[]          @relation("ArticleAuthor")
  contributions        CaseContribution[] @relation("Contributor")
  reviewedContributions CaseContribution[] @relation("Reviewer")
  activityLogs         ActivityLog[]

  @@map("users")
}

model Category {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  color     String   @default("#1a56db")
  icon      String   @default("scale")
  cases     Case[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Defendant {
  id          String   @id @default(uuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  name        String
  role        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("defendants")
}

model Case {
  id            String             @id @default(uuid())
  caseNumber    String             @unique
  title         String
  description   String
  categoryId    String
  category      Category           @relation(fields: [categoryId], references: [id])
  currentStatus CaseStatus         @default(PELAPORAN)
  isActive      Boolean            @default(true)
  defendants    Defendant[]
  stages        CaseStage[]
  contributions CaseContribution[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@map("cases")
}

model CaseStage {
  id        String      @id @default(uuid())
  caseId    String
  case      Case        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  stageType CaseStatus
  status    StageStatus @default(PENDING)
  startedAt DateTime    @default(now())
  endedAt   DateTime?
  article   Article?    @relation("StageArticle")
  createdById String
  createdBy   User      @relation("StageCreator", fields: [createdById], references: [id])
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("case_stages")
}

model Article {
  id          String    @id @default(uuid())
  title       String
  content     String    @db.Text
  stageId     String    @unique
  stage       CaseStage @relation("StageArticle", fields: [stageId], references: [id], onDelete: Cascade)
  publishedAt DateTime  @default(now())
  authorId    String
  author      User      @relation("ArticleAuthor", fields: [authorId], references: [id])
  attachments Json      @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("articles")
}

model CaseContribution {
  id              String             @id @default(uuid())
  caseId          String
  case            Case               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId          String
  user            User               @relation("Contributor", fields: [userId], references: [id], onDelete: Cascade)
  description     String             @db.Text
  status          ContributionStatus @default(PENDING)
  proofLinks      Json               @default("[]")
  proofFiles      Json               @default("[]")
  reviewedById    String?
  reviewedBy      User?              @relation("Reviewer", fields: [reviewedById], references: [id])
  rejectionReason String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@map("case_contributions")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@map("activity_logs")
}
